# Copy to .env for local development. Never commit the real .env file.
# In staging/production, these are injected by the deploy platform's secret
# manager (see k8s/secret.yaml.example and terraform/) — not baked into images.

RAILS_ENV=development
RAILS_MASTER_KEY=

DATABASE_URL=postgres://securityreview:securityreview@localhost:5432/securityreview_development
REDIS_URL=redis://localhost:6379/0

# S3 / attachment storage
AWS_REGION=us-east-1
S3_ATTACHMENTS_BUCKET=securityreview-attachments-dev
# Prefer IAM roles (ECS task role / IRSA) in staging+prod. These are only
# used for local development against a real bucket or MinIO.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Comma-separated allowlist enforced by config.hosts in production.
ALLOWED_HOSTS=app.example.com

# Comma-separated CORS origin allowlist (see config/initializers/cors.rb).
CORS_ALLOWED_ORIGINS=https://app.example.com

# Comma-separated CIDRs for the trusted load balancer (X-Forwarded-For trust).
TRUSTED_PROXY_CIDRS=10.0.0.0/8

# Third-party file-scanning vendor (ops-configured, never user-controlled).
SCAN_VENDOR_API_URL=https://scanner.vendor.example.com
SCAN_VENDOR_API_KEY=

# HMAC secret shared with the third-party scan-results webhook sender.
SCAN_WEBHOOK_SIGNING_SECRET=

# ActiveRecord::Encryption keys (encrypts WebhookEndpoint#signing_secret at
# rest). Generate with `bin/rails db:encryption:init` once, then store the
# three values in the real secret manager — never in this repo.
AR_ENCRYPTION_PRIMARY_KEY=
AR_ENCRYPTION_DETERMINISTIC_KEY=
AR_ENCRYPTION_KEY_DERIVATION_SALT=

RAILS_LOG_LEVEL=info
RAILS_SERVE_STATIC_FILES=false
