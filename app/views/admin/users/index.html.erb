<h1>Users</h1>
<%= link_to "New user", new_admin_user_path %>
<table>
  <thead><tr><th>Email</th><th>Organization</th><th>Role</th></tr></thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= link_to user.email, admin_user_path(user) %></td>
        <td><%= user.organization&.name || "—" %></td>
        <td><%= user.platform_admin? ? "platform admin" : user.role %></td>
      </tr>
    <% end %>
  </tbody>
</table>
