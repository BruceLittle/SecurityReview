# TEMPLATE ONLY — never apply this file as-is and never fill in real
# values here. In every real environment, secrets are created by the
# deploy pipeline (from its own secret manager) or synced from AWS
# Secrets Manager / SSM Parameter Store via the external-secrets operator,
# not committed to this repo. This file documents the *shape* the app
# expects, nothing more.
apiVersion: v1
kind: Secret
metadata:
  name: security-review-secrets
  namespace: security-review
type: Opaque
stringData:
  RAILS_MASTER_KEY: "REPLACE_ME"
  DATABASE_URL: "REPLACE_ME"
  REDIS_URL: "REPLACE_ME"
  S3_ATTACHMENTS_BUCKET: "REPLACE_ME"
  SCAN_VENDOR_API_URL: "REPLACE_ME"
  SCAN_VENDOR_API_KEY: "REPLACE_ME"
  SCAN_WEBHOOK_SIGNING_SECRET: "REPLACE_ME"
  AR_ENCRYPTION_PRIMARY_KEY: "REPLACE_ME"
  AR_ENCRYPTION_DETERMINISTIC_KEY: "REPLACE_ME"
  AR_ENCRYPTION_KEY_DERIVATION_SALT: "REPLACE_ME"
  # AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are deliberately absent: the
  # cluster nodes/pods use IRSA (IAM Roles for Service Accounts) instead
  # (see serviceaccount.yaml), so no long-lived AWS credential needs to
  # exist here at all.
